<!--result.wxml-->
<view class="container">
  <view class="date-info">
    <text class="label">公历日期</text>
    <text class="value">{{solarDate}}</text>
  </view>

  <view class="date-info">
    <text class="label">农历日期</text>
    <text class="value">{{lunarDate}}</text>
  </view>

  <view class="date-info" wx:if="{{solarTerm}}">
    <text class="label">节气</text>
    <text class="value">{{solarTerm}}</text>
  </view>

  <view class="date-info" wx:if="{{festival}}">
    <text class="label">节日</text>
    <text class="value">{{festival}}</text>
  </view>

  <view class="section">
    <view class="content-wrapper">
      <text class="section-content">{{displayContent}}<text class="cursor" wx:if="{{isPlaying}}">▌</text></text>
    </view>
    <view class="actions" wx:if="{{!isPlaying && displayContent}}">
      <view class="action-btn" bindtap="copy">
        <text>复制文案</text>
      </view>
      <view class="action-btn" bindtap="replay">
        <text>重新品读</text>
      </view>
    </view>
  </view>
</view>
/**index.wxss**/
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f0e8 0%, #e8dcc8 100%);
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #8b4513;
  margin-top: 80rpx;
  margin-bottom: 100rpx;
}

.picker-section {
  width: 100%;
  margin-bottom: 80rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
}

.date-picker {
  width: 100%;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-sizing: border-box;
  border: 2rpx solid #d4c4a8;
}

.picker-value {
  font-size: 32rpx;
  color: #333;
  text-align: center;
}

.btn-start {
  width: 80%;
  background: #8b4513;
  color: #fff;
  font-size: 32rpx;
  border-radius: 50rpx;
  margin-top: 40rpx;
}

.btn-start[disabled] {
  background: #ccc;
}
<!--index.wxml-->
<view class="container">
  <view class="title">传统文化日期解读</view>

  <view class="picker-section">
    <text class="label">选择公历日期</text>
    <picker mode="date" value="{{date}}" bindchange="onDateChange" class="date-picker">
      <view class="picker-value">{{date || '请选择日期'}}</view>
    </picker>
  </view>

  <button class="btn-start" bindtap="startReading" disabled="{{!date}}">开始解读</button>
</view>